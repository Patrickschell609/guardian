# GUARDIAN - Cross-Family Threat Hunting
# At least one API key required. More families = better consensus.

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# xAI (Grok)
XAI_API_KEY=xai-...

# Google (Gemini)
GEMINI_API_KEY=AI...

# Model overrides (litellm format)
# GUARDIAN_PRIMARY=anthropic/claude-sonnet-4-20250514
# GUARDIAN_SECONDARY=xai/grok-3-mini-beta
# GUARDIAN_TERTIARY=google/gemini-2.0-flash

# Storage
# GUARDIAN_VAULT=./guardian_vault.db
# GUARDIAN_GRAPH=./guardian_graph.db

# Thresholds
# GUARDIAN_THRESHOLD=7
# GUARDIAN_MAX_TOKENS=4096
